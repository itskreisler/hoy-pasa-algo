---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.tsx';
import Footer from '../components/Footer.tsx';
import { userService } from '../services/userService';
import { profilePageText } from '../constants/profilePage';

const user = await userService.getUser();
---

<Layout title={profilePageText.title}>
  <Header client:load />
  <main class="container mx-auto px-4">
    <div class="text-center py-20">
      <h1 class="text-5xl font-bold mb-4">{profilePageText.title}</h1>
      {user ? (
        <div>
          <p class="text-xl">{profilePageText.loggedIn(user.email)}</p>
          <button class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded mt-4" onClick={() => {
            userService.logout();
            window.location.href = '/';
          }}>
            {profilePageText.logoutButton}
          </button>
        </div>
      ) : (
        <p class="text-xl">{profilePageText.loggedOut}</p>
      )}
    </div>
  </main>
  <Footer client:load />
</Layout>
