---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.tsx';
import Footer from '../components/Footer.tsx';
import Button from '../components/Button.tsx';
import { landingPageText } from '../constants/landingPage';
---

<Layout
  title="Hoy Pasa Algo - Eventos Locales en Tiempo Real"
  description="Descubre los mejores eventos locales en tu ciudad. Conciertos, festivales, deportes y más. ¡No te pierdas nada!">
  <Header client:load />
  <main class="container mx-auto px-4">
    <div class="text-center py-20">
      <h1 class="text-5xl font-bold mb-4">{landingPageText.title}</h1>
      <p class="text-xl mb-8">{landingPageText.subtitle}</p>
      <a href="/explore">
        <Button>{landingPageText.exploreButton}</Button>
      </a>
    </div>
  </main>
  <Footer client:load />
</Layout>
